# --- OpenAI ---
# Used for LLM intent fallback and the per-turn lead extraction call.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Twilio (phone + owner SMS) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+17145557280

# --- Owner SMS notifications ---
# Where the AI texts a one-line lead summary every time a qualified lead is captured.
OWNER_SMS_NUMBER=+15555550100

# --- Storage ---
CHROMA_DB_PATH=./chroma_db

# --- App settings ---
API_BASE_URL=http://localhost:8000
ENVIRONMENT=development
LOG_LEVEL=INFO
DEFAULT_BUSINESS_ID=oc_elite_detailing

# --- Owner dashboard ---
# Where the backend redirects /owner/orders and /inbox to.
OWNER_DASHBOARD_URL=http://localhost:3002/inbox
