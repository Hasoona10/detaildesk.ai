# Copy this file to `.env` (which is gitignored) and fill in real values.
# DO NOT put real secrets in this file — it is committed to source control.

# Twilio Credentials (REQUIRED for phone calls + owner SMS)
# Get from: https://console.twilio.com  (Account Info panel)

# Account SID (always required). Starts with "AC..." -- NOT an OpenAI key.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTION A (recommended): API Key + Secret.
# Console -> Account -> API keys & tokens -> Create API key.
# SID starts with "SK...". Secret is shown ONCE on creation.
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_twilio_api_key_secret_here

# OPTION B (fallback): Primary Auth Token. Only used if API Key isn't set.
TWILIO_AUTH_TOKEN=

TWILIO_PHONE_NUMBER=+15555550123

# Phone number where the AI texts new lead summaries.
# Leave blank in dev to no-op SMS (the lead is still captured and shown in the dashboard).
OWNER_SMS_NUMBER=+15555550123

# OpenAI API Key (REQUIRED for AI responses)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Storage
CHROMA_DB_PATH=./chroma_db

# Application Settings
API_BASE_URL=http://localhost:8000
ENVIRONMENT=development
LOG_LEVEL=INFO
DEFAULT_BUSINESS_ID=oc_elite_detailing
OWNER_DASHBOARD_URL=http://localhost:3002/inbox
